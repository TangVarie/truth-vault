# ════════════════════════════════════════════════════════════════════
# Truth Vault sync scripts · environment variables
# ════════════════════════════════════════════════════════════════════
#
# 1. cp .env.example .env
# 2. 把下面的占位符换成实际值
# 3. 不要 commit .env 到 git（已在 .gitignore 里）
# 4. 在生产环境用 GitHub Secrets / 系统 env vars / vault 注入，不要明文存
#
# ════════════════════════════════════════════════════════════════════

# ── Supabase（共享实例）────────────────────────────────────────────────
# 从 Supabase Dashboard → Settings → API 拿
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# ⚠ service_role secret，不是 anon。看 Settings → API → service_role
# 这个 key 绕过 RLS，绝不能进前端 / 客户端。
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.XXXXXXXX...

# ── 飞书 (仅 sync_feishu_notes_to_truth_vault.py 需要) ───────────────
# 飞书开放平台 → 你的应用 → 凭证与基础信息
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# (可选) 如果 mapping yaml 没在 sync_config 里指定 feishu_app_token / table_id，
# 可以用 env vars 覆盖。但建议直接写在 yaml 里。
# FEISHU_APP_TOKEN=bascn........
# FEISHU_TABLE_ID=tbl........

# ── autowriter sync 用户 (仅 sync_truth_vault_baokuan_to_autowriter_items.py 需要) ──
# autowriter.items.user_id 是 NOT NULL。TV sync 写入的 item 需要挂一个
# user_id。建议在 autowriter 的 auth.users 里专门建一个 service account
# （比如 truth_vault_sync@v.fanggu.local），把它的 UUID 填这里。
AUTOWRITER_SYNC_USER_ID=00000000-0000-0000-0000-000000000000

# ── Anthropic (仅 annotate_essence_pass.py 需要) ────────────────────
# 从 https://console.anthropic.com/settings/keys 拿
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 模型 ID. 默认 claude-sonnet-4-6. 上线前查
# https://docs.anthropic.com/en/docs/about-claude/models 核实最新 ID.
ESSENCE_MODEL=claude-sonnet-4-6

# ── 日志级别 (可选) ──────────────────────────────────────────────────
LOG_LEVEL=INFO
