# 飞轮总看板 env(服务端用,绝不进浏览器、绝不提交进 git)。
# Vercel 部署:Project → Settings → Environment Variables 配同名变量(Production + Preview)。
#
# 看板只读 public.v_dash_overview 这一个安全聚合视图(docs/24 §3),
# 所以用**最小权限 anon / publishable key** 即可(读不到 truth_vault / autowriter 原始行)。
SUPABASE_URL=https://kduysqedrclrfevrxiie.supabase.co

# anon(JWT)或 sb_publishable_… key —— 从 Supabase 项目 Settings → API 拿。
# ⚠️ 本共享库 public schema 目前 anon 可读(三生六部数据),故此 key 仍勿外泄;只服务端用。
SUPABASE_ANON_KEY=__在此填 anon / publishable key__

# (兼容)若历史上配过 service_role,代码也认;但公开看板建议用上面的 anon。
# SUPABASE_SERVICE_ROLE_KEY=
